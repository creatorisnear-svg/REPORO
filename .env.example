# Aviv Bot - Environment Variables
# Copy this to .env and fill in your values

# Discord Bot
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id

# Turso Database (https://turso.tech)
TURSO_DATABASE_URL=libsql://your-db-name-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Stripe Payments (optional - for subscription billing)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Express Session
SESSION_SECRET=a_very_long_random_string_here

# Dashboard API key (optional)
DASHBOARD_API_KEY=

# Server port (set automatically by Replit/Koyeb)
PORT=5000
